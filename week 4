/* ============================================================
 *  6. HELPER — print utilities
 * ============================================================ */
static const char *sensor_name(int id) {
    switch (id) {
        case SENSOR_TEMP: return "TEMP";
        case SENSOR_HUM:  return "HUM ";
        case SENSOR_SOIL: return "SOIL";
        default:          return "????";
    }
}

static const char *sensor_unit(int id) {
    switch (id) {
        case SENSOR_TEMP: return "°C ";
        case SENSOR_HUM:  return "%RH";
        case SENSOR_SOIL: return "ADC";
        default:          return "   ";
    }
}

static const char *priority_label(int p) {
    switch (p) {
        case PRIORITY_CRITICAL: return "CRITICAL";
        case PRIORITY_WARNING:  return "WARNING ";
        default:                return "INFO    ";
    }
}

/* ============================================================
 *  7. MAIN — acquisition loop
 * ============================================================ */
int main(void) {
    printf("=======================================================\n");
    printf("  Real-Time Multi-Sensor Data Acquisition System\n");
    printf("  Week 4 — Algorithm Demonstration\n");
    printf("  Soroti University  |  CPE2206  |  Group 1\n");
    printf("=======================================================\n\n");

    /* --- Initialise circular buffers --- */
    CircularBuffer buffers[NUM_SENSORS];
    int buf_sizes[NUM_SENSORS] = {TEMP_BUF_SIZE, HUM_BUF_SIZE, SOIL_BUF_SIZE};
    for (int s = 0; s < NUM_SENSORS; s++)
        cb_init(&buffers[s], buf_sizes[s]);

    /* --- Initialise moving-average state --- */
    MovingAvg ma[NUM_SENSORS];
    int win[NUM_SENSORS] = {TEMP_WIN, HUM_WIN, SOIL_WIN};
    for (int s = 0; s < NUM_SENSORS; s++)
        ma_init(&ma[s], win[s]);

    /* --- Initialise priority queue --- */
    PriorityQueue pq;
    pq_init(&pq);

    /* --- Threshold tables (low, high, priority) --- */
    float low_thresh [NUM_SENSORS] = {TEMP_LOW,  HUM_LOW,  SOIL_LOW };
    float high_thresh[NUM_SENSORS] = {TEMP_HIGH, HUM_HIGH, SOIL_HIGH};
    int   priorities [NUM_SENSORS] = {PRIORITY_CRITICAL,
                                      PRIORITY_WARNING,
                                      PRIORITY_WARNING};

    /* ── MAIN ACQUISITION LOOP ──────────────────────────────── */
    int total_events = 0;

    for (int cycle = 0; cycle < (int)SIM_CYCLES; cycle++) {
        long ts = (long)cycle + 1;   /* simulated 1-second ticks */

        printf("── Cycle %2ld ─────────────────────────────────────────\n",
               ts);

        for (int s = 0; s < NUM_SENSORS; s++) {
            /* Step 1: Read sensor (simulated or real) */
            float raw = sensor_read(s, cycle);

            /* Step 2: Write to circular buffer — O(1) */
            cb_write(&buffers[s], raw);

            /* Step 3: Compute moving average — O(1) */
            float avg = ma_update(&ma[s], &buffers[s]);

            printf("  [%s] raw=%7.2f %s  avg=%7.2f %s",
                   sensor_name(s), raw, sensor_unit(s),
                   avg, sensor_unit(s));

            /* Step 4: Anomaly detection — O(1) */
            Event ev;
            memset(&ev, 0, sizeof(ev));
            if (anomaly_check(s, avg,
                              low_thresh[s], high_thresh[s],
                              priorities[s], &ev, ts)) {
                printf("  *** %s: %s %s threshold (%.2f %s)",
                       priority_label(ev.priority),
                       sensor_name(s),
                       ev.direction < 0 ? "BELOW LOW" : "ABOVE HIGH",
                       ev.threshold,
                       sensor_unit(s));
                /* Step 5: Enqueue event — O(log N) */
                if (pq_insert(&pq, ev) == 0)
                    total_events++;
                else
                    printf("  [PQ FULL - event dropped]");
            }
            printf("\n");
        }
        printf("\n");
    }

    /* ── DRAIN PRIORITY QUEUE ─────────────────────────────── */
    printf("=======================================================\n");
    printf("  Priority Queue — %d event(s) pending\n", pq.size);
    printf("=======================================================\n");
    int rank = 1;
    while (!pq_is_empty(&pq)) {
        Event e = pq_extract(&pq);
        printf("  [%d] %s | sensor=%-4s | avg=%7.2f | ts=%lds\n",
               rank++,
               priority_label(e.priority),
               sensor_name(e.sensor_id),
               e.value,
               e.timestamp);
    }

    /* ── MEMORY SUMMARY ──────────────────────────────────────  */
    printf("\n=======================================================\n");
    printf("  Static Memory Footprint\n");
    printf("=======================================================\n");
    int buf_bytes = 0;
    for (int s = 0; s < NUM_SENSORS; s++)
        buf_bytes += buf_sizes[s] * (int)sizeof(float);
    int pq_bytes   = PQ_CAPACITY * (int)sizeof(Event);
    int ma_bytes   = NUM_SENSORS * (int)sizeof(MovingAvg);
    int total_bytes = buf_bytes + pq_bytes + ma_bytes;
    printf("  Circular buffers : %4d bytes\n", buf_bytes);
    printf("  Priority queue   : %4d bytes\n", pq_bytes);
    printf("  Moving-avg state : %4d bytes\n", ma_bytes);
    printf("  ─────────────────────────────\n");
    printf("  Total            : %4d bytes  (%.1f%% of 64 KB)\n",
           total_bytes, total_bytes / 655.36);

    /* ── CLEANUP ─────────────────────────────────────────────  */
    for (int s = 0; s < NUM_SENSORS; s++)
        cb_free(&buffers[s]);

    printf("\nDone. Total anomaly events raised: %d\n", total_events);
    return 0;
}
