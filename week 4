/* ── Build switch ─────────────────────────────────────────── */
#define SIMULATION 1   /* 1 = desktop sim, 0 = real ESP32 HW  */

/* ── Sensor channel indices ───────────────────────────────── */
#define SENSOR_TEMP   0
#define SENSOR_HUM    1
#define SENSOR_SOIL   2
#define NUM_SENSORS   3

/* ── Circular buffer sizes (from Week 2 memory analysis) ──── */
#define TEMP_BUF_SIZE   60   /* 60 s of history @ 1 Hz          */
#define HUM_BUF_SIZE    60
#define SOIL_BUF_SIZE   60

/* ── Moving-average window sizes ─────────────────────────── */
#define TEMP_WIN   5
#define HUM_WIN    5
#define SOIL_WIN   10

/* ── Anomaly thresholds ───────────────────────────────────── */
#define TEMP_LOW    10.0f    /* °C  */
#define TEMP_HIGH   40.0f
#define HUM_LOW     20.0f    /* %RH */
#define HUM_HIGH    90.0f
#define SOIL_LOW   500.0f    /* ADC */
#define SOIL_HIGH 3500.0f

/* ── Priority queue capacity ─────────────────────────────── */
#define PQ_CAPACITY 16

/* ── Sentinel for invalid readings ──────────────────────── */
#define INVALID_VAL (-9999.0f)

/* ============================================================
 *  1. CIRCULAR BUFFER
 * ============================================================ */
typedef struct {
    float  *data;       /* heap-allocated array                 */
    int     size;       /* allocated capacity                   */
    int     head;       /* next write position                  */
    int     tail;       /* oldest element position              */
    int     count;      /* number of valid elements             */
    double  running_sum;/* kept for O(1) moving-average update  */
} CircularBuffer;

/**
 * cb_init — allocate and initialise a circular buffer.
 * O(size) to zero the array; O(1) thereafter per operation.
 */
void cb_init(CircularBuffer *cb, int size) {
    cb->data        = (float *)calloc(size, sizeof(float));
    cb->size        = size;
    cb->head        = 0;
    cb->tail        = 0;
    cb->count       = 0;
    cb->running_sum = 0.0;
}

/**
 * cb_write — write one value; overwrite oldest on overflow.
 * Time: O(1)   Space: O(1) additional
 */
void cb_write(CircularBuffer *cb, float value) {
    if (cb->count == cb->size) {
        /* Buffer full: evict the oldest element first */
        cb->running_sum -= cb->data[cb->tail];
        cb->tail = (cb->tail + 1) % cb->size;
        cb->count--;
    }
    cb->running_sum    += value;
    cb->data[cb->head]  = value;
    cb->head            = (cb->head + 1) % cb->size;
    cb->count++;
}

/**
 * cb_read_latest — return the most recent value without removing it.
 * Time: O(1)
 */
float cb_read_latest(const CircularBuffer *cb) {
    if (cb->count == 0) return INVALID_VAL;
    int idx = (cb->head - 1 + cb->size) % cb->size;
    return cb->data[idx];
}

/**
 * cb_read_at_offset — return element 'offset' positions before head.
 * Offset 0 = newest, offset (count-1) = oldest.
 * Time: O(1)
 */
float cb_read_at_offset(const CircularBuffer *cb, int offset) {
    if (offset < 0 || offset >= cb->count) return INVALID_VAL;
    int idx = (cb->head - 1 - offset + cb->size * 2) % cb->size;
    return cb->data[idx];
}

void cb_free(CircularBuffer *cb) {
    free(cb->data);
    cb->data = NULL;
}

/* ============================================================
 *  2. MOVING AVERAGE  (Sliding-Window / Divide-and-Conquer)
 * ============================================================ */
typedef struct {
    double  sum;         /* running window sum                  */
    int     window;      /* window width W                      */
    int     filled;      /* 1 once W samples have been seen     */
} MovingAvg;

void ma_init(MovingAvg *ma, int window) {
    ma->sum    = 0.0;
    ma->window = window;
    ma->filled = 0;
}

/**
 * ma_update — compute the new moving average given the circular buffer.
 *
 * Recurrence (divide-and-conquer):
 *   avg[n] = avg[n-1] + (x[n] - x[n-W]) / W
 *
 * This reuses the previously solved sub-problem (avg[n-1]) and
 * adds only the marginal delta, giving O(1) per update.
 *
 * Time: O(1)   Space: O(1)
 */
float ma_update(MovingAvg *ma, const CircularBuffer *cb) {
    int W = ma->window;
    if (cb->count < W) {
        /* Not enough history: simple mean of what we have       */
        if (cb->count == 0) return INVALID_VAL;
        return (float)(cb->running_sum / cb->count);
    }

    /* Sliding-window recurrence */
    float x_new = cb_read_at_offset(cb, 0);        /* newest   */
    float x_old = cb_read_at_offset(cb, W);        /* leaving  */

    if (!ma->filled) {
        /* Bootstrap: sum the first W elements directly          */
        ma->sum    = 0.0;
        for (int i = 0; i < W; i++)
            ma->sum += cb_read_at_offset(cb, i);
        ma->filled = 1;
    } else {
        ma->sum = ma->sum + x_new - x_old;
    }
    return (float)(ma->sum / W);
}

/* ============================================================
 *  3. ANOMALY DETECTION
 * ============================================================ */
#define PRIORITY_CRITICAL 1
#define PRIORITY_WARNING  2
#define PRIORITY_INFO     3

typedef struct {
    int   sensor_id;
    float value;
    float threshold;
    int   direction;   /* -1 = below low, +1 = above high       */
    int   priority;
    long  timestamp;
} Event;

/**
 * anomaly_check — compare moving average against thresholds.
 * Fills *out_event if a violation is found.
 * Returns 1 if anomaly detected, 0 otherwise.
 * Time: O(1)
 */
int anomaly_check(int sensor_id, float avg,
                  float low, float high,
                  int priority_level,
                  Event *out_event, long ts) {
    int triggered = 0;
    if (avg < low) {
        out_event->direction = -1;
        out_event->threshold = low;
        triggered = 1;
    } else if (avg > high) {
        out_event->direction = +1;
        out_event->threshold = high;
        triggered = 1;
    }
    if (triggered) {
        out_event->sensor_id = sensor_id;
        out_event->value     = avg;
        out_event->priority  = priority_level;
        out_event->timestamp = ts;
    }
    return triggered;
}

/* ============================================================
 *  4. PRIORITY QUEUE (Min-Heap, array-based)
 * ============================================================ */
typedef struct {
    Event data[PQ_CAPACITY];
    int   size;
} PriorityQueue;

void pq_init(PriorityQueue *pq) { pq->size = 0; }

static void pq_swap(PriorityQueue *pq, int a, int b) {
    Event tmp = pq->data[a];
    pq->data[a] = pq->data[b];
    pq->data[b] = tmp;
}

/**
 * pq_insert — insert event; bubble up to restore heap property.
 * Time: O(log N)   Space: O(1) additional
 */
int pq_insert(PriorityQueue *pq, Event e) {
    if (pq->size >= PQ_CAPACITY) return -1;   /* queue full     */
    pq->data[pq->size] = e;
    int i = pq->size++;
    while (i > 0) {
        int parent = (i - 1) / 2;
        if (pq->data[parent].priority > pq->data[i].priority) {
            pq_swap(pq, parent, i);
            i = parent;
        } else break;
    }
    return 0;
}

/**
 * pq_extract — remove and return the highest-priority event.
 * Time: O(log N)
 */
Event pq_extract(PriorityQueue *pq) {
    Event result = pq->data[0];
    pq->data[0]  = pq->data[--pq->size];
    int i = 0;
    while (1) {
        int left  = 2 * i + 1;
        int right = 2 * i + 2;
        int smallest = i;
        if (left  < pq->size &&
            pq->data[left].priority  < pq->data[smallest].priority)
            smallest = left;
        if (right < pq->size &&
            pq->data[right].priority < pq->data[smallest].priority)
            smallest = right;
        if (smallest == i) break;
        pq_swap(pq, i, smallest);
        i = smallest;
    }
    return result;
}

int pq_is_empty(const PriorityQueue *pq) { return pq->size == 0; }

/* ============================================================
 *  5. SENSOR SIMULATION
